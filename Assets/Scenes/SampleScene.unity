  - Text: "\u041F\u0440\u0438\u0432\u0435\u0442"
    Choices:
    - Text: "\u041F\u0440\u0438\u0432\u0435\u0442!"
      NextNodeIndex: 1
      IsEnd: 0
    IsEnd: 0
  - Text: "\u041A\u0430\u043A \u0443 \u0442\u0435\u0431\u044F \u0434\u0435\u043B\u0430?"
    Choices:
    - Text: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E!"
      NextNodeIndex: 2
      IsEnd: 0
    - Text: "\u041F\u043B\u043E\u0445\u043E!"
      NextNodeIndex: 3
      IsEnd: 0
    IsEnd: 0
  - Text: "\u042F \u0437\u0430 \u0442\u0435\u0431\u044F \u0440\u0430\u0434! \u0415\u0441\u043B\u0438
      \u0442\u044B \u043D\u0435 \u0437\u0430\u043D\u044F\u0442, \u0442\u044B \u043C\u043E\u0433
      \u0431\u044B \u043F\u043E\u043C\u043E\u0447\u044C \u043C\u043E\u0435\u043C\u0443
      \u0434\u0440\u0443\u0433\u0443! \u041E\u043D \u0441\u0442\u043E\u0438\u0442
      \u0440\u044F\u0434\u043E\u043C \u0441\u043E \u043C\u043D\u043E\u0439\""
    Choices:
    - Text: "\u0425\u043E\u0440\u043E\u0448\u043E! \u0414\u043E \u0441\u043A\u043E\u0440\u044B\u0445
        \u0432\u0441\u0442\u0440\u0435\u0447!"
      NextNodeIndex: 0
      IsEnd: 1
    IsEnd: 1
  - Text: "\u041F\u043E\u0447\u0435\u043C\u0443?"
    Choices:
    - Text: "\u042F \u043D\u0435 \u0437\u043D\u0430\u044E \u0447\u0435\u043C \u0437\u0430\u043D\u044F\u0442\u044C\u0441\u044F"
      NextNodeIndex: 4
      IsEnd: 0
    - Text: "\u042D\u0442\u043E \u043D\u0435 \u0442\u0432\u043E\u0435 \u0434\u0435\u043B\u043E!"
      NextNodeIndex: 5
      IsEnd: 0
    IsEnd: 0
  - Text: "\u0415\u0441\u043B\u0438 \u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C,
      \u0442\u044B \u0431\u044B \u043C\u043E\u0433 \u043F\u043E\u043C\u043E\u0447\u044C
      \u043C\u043E\u0435\u043C\u0443 \u0434\u0440\u0443\u0433\u0443, \u043E\u043D
      \u0441\u0442\u043E\u0438\u0442 \u0440\u044F\u0434\u043E\u043C!\""
    Choices:
    - Text: "\u0425\u043E\u0440\u043E\u0448\u043E, \u0441\u0435\u0439\u0447\u0430\u0441
        \u044F \u043F\u043E\u0434\u043E\u0439\u0434\u0443 \u043A \u043D\u0435\u043C\u0443!"
      NextNodeIndex: 0
      IsEnd: 1
    IsEnd: 1
  - Text: "\u0412 \u0442\u0430\u043A\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435
      \u044F \u043D\u0438\u0447\u0435\u043C \u043D\u0435 \u043C\u043E\u0433\u0443
      \u0442\u0435\u0431\u0435 \u043F\u043E\u043C\u043E\u0447\u044C! \u0412\u0441\u0435\u0433\u043E
      \u0434\u043E\u0431\u0440\u043E\u0433\u043E!"
    Choices:
    - Text: "\u0414\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0438!"
      NextNodeIndex: 0
      IsEnd: 1
    IsEnd: 1
  _questManager: {fileID: 840424189}
  _afterQuestDialogue: []
  _sceneItems: []
